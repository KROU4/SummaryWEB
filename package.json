    "worker:deploy": "wrangler deploy"
  },
  "dependencies": {
    "framer-motion": "^12.23.24",
    "idb": "^8.0.3",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.2",
    "youtube-transcript-plus": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^18.3.24",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0"
